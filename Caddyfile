# HudsonSeed Caddyfile | serves on $PORT | HTML/navigations = no-cache (incl "/"), static = long cache
:{$PORT} {
    root * /srv
    encode gzip

    # static assets: cache hard
    @static {
        path *.css *.js *.jpg *.jpeg *.png *.svg *.webp *.woff *.woff2 *.mp4 *.ico
    }
    header @static Cache-Control "public, max-age=31536000"

    # everything else (homepage "/", *.html, any navigation): never cache
    @nocache {
        not path *.css *.js *.jpg *.jpeg *.png *.svg *.webp *.woff *.woff2 *.mp4 *.ico
    }
    header @nocache Cache-Control "no-cache, no-store, must-revalidate"

    try_files {path} /index.html
    file_server
}
